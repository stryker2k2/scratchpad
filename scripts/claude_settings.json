{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch",
      "Read",
      "Grep",
      "Bash(find:*)",
      "Bash(xargs:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(objdump:*)",
      "Bash(wc:*)",
      "Bash(tail:*)",
      "Bash(head:*)",
      "Bash(which:*)",
      "Bash(cd:*)",
      "Bash(mkdir:*)",
      "Bash(sed:*)",
      "Bash(sort:*)",
      "Bash(echo:*)",
      "Bash(/home/dev/repo/splinternet/build/linux/venv/bin/python:*)",
      "Bash(/home/dev/repo/splinternet/build/linux/venv/bin/pip:*)",
      "Bash(/home/dev/repo/splinternet/build/linux/dev-venv/bin/python:*)",
      "Bash(/home/dev/repo/splinternet/build/linux/dev-venv/bin/pip:*)",
      "Bash(npm run build:*)",
      "Bash(npm list:*)",
      "Bash(npx tsc:*)",
      "Bash(git show:*)",
      "Bash(git ls-tree:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/bash-permissions.py"
          }
        ]
      }
    ]
  },
  "attribution": {
    "commits": false
  },
  "model": "claude-sonnet-4-6",
  "effortLevel": "high",
  "alwaysThinkingEnabled": true
}
